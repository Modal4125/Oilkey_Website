# Resend API key (https://resend.com/api-keys) — required for the contact form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered (defaults to oilkey@oilkey.co.jp)
CONTACT_TO_EMAIL=oilkey@oilkey.co.jp

# Sender address. The default onboarding@resend.dev only delivers to the Resend
# account owner — verify the oilkey.com domain in Resend and use e.g.
# "Oilkey Web <form@oilkey.com>" before launch.
CONTACT_FROM_EMAIL=onboarding@resend.dev
