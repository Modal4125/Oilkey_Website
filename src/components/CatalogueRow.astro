---
interface Props {
  badge: string;
  title: string;
  meta: string;
  href: string;
  label: string;
  /** Opens in a new tab when the href points off-site */
  external?: boolean;
}

const { badge, title, meta, href, label, external = false } = Astro.props;
---

<div
  class="border-line flex flex-col items-start gap-3 border-t px-5 py-5 first:border-t-0 sm:flex-row sm:items-center sm:justify-between sm:px-6"
>
  <div class="flex items-center gap-[18px]">
    <span
      class="border-blueprint text-blueprint rounded-xs border px-[7px] py-1 font-mono text-[10px] font-semibold"
    >
      {badge}
    </span>
    <div>
      <div class="text-sm font-medium">{title}</div>
      <div class="text-steel-light mt-[3px] font-mono text-[11px]">{meta}</div>
    </div>
  </div>
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener' : undefined}
    class="text-ink hover:text-blueprint flex items-center gap-2 py-1 font-mono text-xs"
  >
    {label}
  </a>
</div>
