---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { formatNewsDate } from '../lib/date';
import { news } from '../i18n/news';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
  post: CollectionEntry<'news'>;
}

const { lang, post } = Astro.props;
const t = news[lang];
const { Content } = await render(post);
const listUrl = getRelativeLocaleUrl(lang, '/news');
---

<div class="border-line bg-panel border-b">
  <div class="mx-auto max-w-[820px] px-8 py-[72px]">
    <div class="mb-5 flex items-center gap-4">
      <span class="text-steel-light font-mono text-xs">{formatNewsDate(post.data.date)}</span>
      <span
        class="border-blueprint text-blueprint rounded-xs border px-2 py-0.5 font-mono text-[10px]"
      >
        {post.data.tag}
      </span>
    </div>
    <h1 class="text-[clamp(26px,3vw,38px)] leading-[1.4]">{post.data.title}</h1>
  </div>
</div>

<section class="py-16">
  <div class="mx-auto max-w-[820px] px-8">
    <article class="news-body text-[15px]">
      <Content />
    </article>
    <a href={listUrl} class="text-blueprint mt-12 inline-block font-mono text-xs font-medium">
      {t.backToList}
    </a>
  </div>
</section>

<style>
  .news-body :global(p) {
    margin-bottom: 1.4em;
  }
  .news-body :global(h2) {
    font-size: 20px;
    margin: 2em 0 0.8em;
  }
  .news-body :global(h3) {
    font-size: 17px;
    margin: 1.6em 0 0.6em;
  }
  .news-body :global(ul),
  .news-body :global(ol) {
    margin-bottom: 1.4em;
    padding-left: 1.6em;
  }
  .news-body :global(ul) {
    list-style: disc;
  }
  .news-body :global(ol) {
    list-style: decimal;
  }
  .news-body :global(li) {
    margin-bottom: 0.3em;
  }
  .news-body :global(a) {
    color: var(--color-blueprint);
    text-decoration: underline;
  }
  .news-body :global(a:hover) {
    color: var(--color-blueprint-dark);
  }
</style>
