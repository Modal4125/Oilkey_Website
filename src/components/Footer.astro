---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/home';
import { BLOG_URL } from '../lib/links';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const url = (path: string) => getRelativeLocaleUrl(lang, path);

const t = {
  ja: {
    addressLines: ['〒593-8314', '大阪府堺市西区太平寺617', 'Sakai, Osaka, Japan'],
    cols: [
      {
        heading: 'Company',
        links: [
          { label: '会社案内', href: url('/company') },
          { label: '事業案内', href: url('/business') },
          { label: 'お知らせ', href: BLOG_URL },
        ],
      },
      {
        heading: 'Products',
        links: [
          { label: '取扱製品', href: url('/products') },
          { label: 'グリースガン', href: url('/products') },
          { label: 'カタログ・資料', href: url('/catalogue') },
        ],
      },
      {
        heading: 'Contact',
        links: [
          { label: 'お問い合わせ', href: url('/contact') },
          { label: 'アクセス', href: url('/company') },
          { label: 'プライバシーポリシー', href: url('/privacy') },
        ],
      },
    ],
  },
  en: {
    addressLines: ['617 Taiheiji, Nishi-ku, Sakai', 'Osaka 593-8314, Japan'],
    cols: [
      {
        heading: 'Company',
        links: [
          { label: 'Company', href: url('/company') },
          { label: 'Business', href: url('/business') },
          { label: 'News', href: BLOG_URL },
        ],
      },
      {
        heading: 'Products',
        links: [
          { label: 'Products', href: url('/products') },
          { label: 'Grease Guns', href: url('/products') },
          { label: 'Catalogue & Downloads', href: url('/catalogue') },
        ],
      },
      {
        heading: 'Contact',
        links: [
          { label: 'Contact', href: url('/contact') },
          { label: 'Access', href: url('/company') },
          { label: 'Privacy Policy', href: url('/privacy') },
        ],
      },
    ],
  },
}[lang];
---

<footer class="bg-deep pt-16 pb-8 text-[13px] text-white/70">
  <div class="wrap">
    <div
      class="grid grid-cols-2 gap-10 border-b border-white/[0.14] pb-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]"
    >
      <div>
        <span class="mb-[18px] inline-block rounded-xs bg-white px-3.5 py-2.5">
          <img
            src="/logo.png"
            alt="Oilkey Corporation"
            width="600"
            height="166"
            class="h-[30px] w-auto"
          />
        </span>
        <p class="mb-2.5 leading-[1.9]">
          {t.addressLines.map((line, i) => (i > 0 ? [<br />, line] : line))}
        </p>
        <p class="mb-2.5 font-mono">
          TEL 072-284-1711<br />FAX 072-298-7790
        </p>
        <a href="mailto:oilkey@oilkey.co.jp" class="block hover:text-white">oilkey@oilkey.co.jp</a>
      </div>
      {
        t.cols.map((col) => (
          <div>
            <h4 class="text-amber-bright mb-4 text-xs font-bold tracking-[0.14em] uppercase">
              {col.heading}
            </h4>
            {col.links.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener' : undefined}
                class="mb-1 block py-1 text-white/80 hover:text-white"
              >
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
    </div>
    <div class="flex flex-wrap justify-between gap-2 pt-7 text-[12px] text-white/50">
      <span>© 1963–2026 OILKEY CORPORATION</span>
      <span
        >OKS / BANTLEON / F@ctory Express are registered trademarks of their respective owners</span
      >
    </div>
  </div>
</footer>
