---
import PageHeader from './PageHeader.astro';
import { business } from '../i18n/business';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = business[lang];
---

<PageHeader eyebrow={t.header.eyebrow} heading={t.header.heading} intro={t.header.intro} />

<section class="py-16 lg:py-20">
  <div class="wrap">
    <div class="mb-14 lg:mb-16">
      <p class="max-w-[860px] text-[clamp(17px,2vw,22px)] leading-[1.8] font-bold">
        {t.overview.lead}
      </p>
      <p class="text-steel mt-6 max-w-[820px] text-[15px] leading-[2]">
        {t.overview.body}
      </p>
    </div>
    <div class="grid gap-6 lg:grid-cols-3">
      {
        t.pillars.map((pillar) => (
          <div class="border-line bg-panel border-t-amber rounded-xs border border-t-[3px] px-[30px] py-9">
            <div class="text-amber mb-4 font-mono text-xs">{pillar.tag}</div>
            <h3 class="mb-3 text-[19px] font-bold">{pillar.title}</h3>
            <div class="text-steel space-y-3 text-sm">
              {pillar.paras.map((para) => (
                <p>{para}</p>
              ))}
            </div>
            {pillar.items && (
              <ul class="mt-4">
                {pillar.items.map((item) => (
                  <li class="border-line text-steel border-t py-2.5 text-sm first:border-t-0">
                    {item.label && <strong class="text-ink font-medium">{item.label}</strong>}
                    {item.label && ' — '}
                    {item.text}
                  </li>
                ))}
              </ul>
            )}
            {pillar.after && <p class="text-steel mt-4 text-sm">{pillar.after}</p>}
          </div>
        ))
      }
    </div>
  </div>
</section>
