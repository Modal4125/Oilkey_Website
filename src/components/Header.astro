---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const labels = {
  ja: {
    company: '会社案内',
    business: '事業案内',
    products: '取扱製品',
    catalogue: 'カタログ',
    news: 'お知らせ',
    contact: 'お問い合わせ',
    tel: 'TEL 072-284-1711',
  },
  en: {
    company: 'Company',
    business: 'Business',
    products: 'Products',
    catalogue: 'Catalogue',
    news: 'News',
    contact: 'Contact',
    tel: 'TEL +81-72-284-1711',
  },
}[lang];

const url = (path: string) => getRelativeLocaleUrl(lang, path);

const navItems = [
  { label: labels.company, href: url('/company') },
  { label: labels.business, href: url('/business') },
  { label: labels.products, href: `${url('/')}#products` },
  { label: labels.catalogue, href: url('/catalogue') },
  { label: labels.news, href: url('/news') },
  { label: labels.contact, href: url('/contact') },
];

// Mirror path for the JP/EN toggle: strip any /en prefix, re-localize.
const basePath = Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/';
const jaHref = getRelativeLocaleUrl('ja', basePath);
const enHref = getRelativeLocaleUrl('en', basePath);

const toggleBase = 'rounded-xs border px-[9px] py-[3px]';
const toggleActive = 'border-ink bg-ink text-paper';
const toggleIdle = 'border-line-dark text-steel';
---

<header class="border-line bg-paper/92 sticky top-0 z-50 border-b backdrop-blur-[8px]">
  <div class="wrap flex h-[76px] items-center justify-between">
    <a
      href={url('/')}
      class="font-display flex items-center gap-2.5 text-[22px] font-black tracking-[0.02em]"
    >
      <span
        class="border-ink bg-ink text-paper flex h-[34px] w-[34px] items-center justify-center rounded-xs border-2"
      >
        <span class="font-mono text-[13px] font-semibold">OK</span>
      </span>
      <span>
        OILKEY
        <small class="text-steel mt-0.5 block font-mono text-[10px] font-normal tracking-[0.08em]">
          OILKEY CORPORATION EST. 1963
        </small>
      </span>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex gap-9">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="after:bg-amber relative py-1 text-sm font-medium after:absolute after:-bottom-0.5 after:left-0 after:h-0.5 after:w-0 after:transition-[width] after:duration-200 after:content-[''] hover:after:w-full"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-[22px]">
      <span class="text-steel hidden font-mono text-[13px] lg:inline">{labels.tel}</span>
      <div class="flex items-center gap-1.5 font-mono text-xs">
        <a href={jaHref} class:list={[toggleBase, lang === 'ja' ? toggleActive : toggleIdle]}>JP</a>
        <a href={enHref} class:list={[toggleBase, lang === 'en' ? toggleActive : toggleIdle]}>EN</a>
      </div>
      <button
        id="menu-btn"
        type="button"
        class="text-2xl lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        ≡
      </button>
    </div>
  </div>

  <div id="mobile-nav" hidden class="border-line border-t lg:hidden">
    <ul class="wrap flex flex-col py-4">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class="block py-2 text-sm font-medium">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const panel = document.getElementById('mobile-nav');
  if (btn && panel) {
    btn.addEventListener('click', () => {
      const nowHidden = panel.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', String(!nowHidden));
    });
  }
</script>
