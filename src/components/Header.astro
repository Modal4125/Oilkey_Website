---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const labels = {
  ja: {
    company: '会社案内',
    business: '事業案内',
    products: '取扱製品',
    catalogue: 'カタログ',
    news: 'お知らせ',
    contact: 'お問い合わせ',
    tel: 'TEL 072-284-1711',
  },
  en: {
    company: 'Company',
    business: 'Business',
    products: 'Products',
    catalogue: 'Catalogue',
    news: 'News',
    contact: 'Contact',
    tel: 'TEL +81-72-284-1711',
  },
}[lang];

const url = (path: string) => getRelativeLocaleUrl(lang, path);

// English sub-labels under the Japanese nav items, per the Trust template.
const subs =
  lang === 'ja'
    ? ['Company', 'Business', 'Products', 'Catalogue', 'News']
    : [undefined, undefined, undefined, undefined, undefined];

const navItems = [
  { label: labels.company, sub: subs[0], href: url('/company') },
  { label: labels.business, sub: subs[1], href: url('/business') },
  { label: labels.products, sub: subs[2], href: url('/products') },
  { label: labels.catalogue, sub: subs[3], href: url('/catalogue') },
  { label: labels.news, sub: subs[4], href: url('/news') },
];

const contactItem = { label: labels.contact, href: url('/contact') };

// Mirror path for the JP/EN toggle: strip any /en prefix, re-localize.
const basePath = Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/';
const jaHref = getRelativeLocaleUrl('ja', basePath);
const enHref = getRelativeLocaleUrl('en', basePath);

// Larger padding below lg keeps the JP/EN switch comfortably tappable.
const toggleBase = 'rounded-xs border px-2.5 py-1.5 lg:px-[9px] lg:py-[3px]';
const toggleActive = 'border-ink bg-ink text-paper';
const toggleIdle = 'border-line-dark text-steel';
---

<header class="border-line bg-paper/92 sticky top-0 z-50 border-b backdrop-blur-[8px]">
  <div class="wrap flex h-[76px] items-center justify-between">
    <a
      href={url('/')}
      class="flex items-center dark:rounded-xs dark:bg-white dark:px-2 dark:py-1"
      aria-label="Oilkey Corporation home"
    >
      <img
        src="/logo.png"
        alt="Oilkey Corporation"
        width="600"
        height="166"
        class="h-[38px] w-auto dark:h-[34px]"
      />
    </a>

    <nav class="hidden lg:block">
      <ul class="flex items-center gap-[26px]">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-steel hover:text-amber block text-sm font-medium transition-colors"
              >
                {item.label}
                {item.sub && (
                  <span class="block text-[11px] font-normal opacity-60">{item.sub}</span>
                )}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={contactItem.href}
            class="bg-amber hover:bg-amber-bright rounded-xs px-[18px] py-[9px] text-[13px] font-bold text-white transition-colors"
          >
            {contactItem.label}
          </a>
        </li>
      </ul>
    </nav>

    <div class="flex items-center gap-[22px]">
      <span class="text-steel hidden font-mono text-[13px] lg:inline">{labels.tel}</span>
      <div class="flex items-center gap-1.5 font-mono text-xs">
        <a href={jaHref} class:list={[toggleBase, lang === 'ja' ? toggleActive : toggleIdle]}>JP</a>
        <a href={enHref} class:list={[toggleBase, lang === 'en' ? toggleActive : toggleIdle]}>EN</a>
      </div>
      <button
        id="menu-btn"
        type="button"
        class="-mr-2.5 flex h-11 w-11 items-center justify-center text-2xl lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Menu"
      >
        ≡
      </button>
    </div>
  </div>

  <div id="mobile-nav" hidden class="border-line border-t lg:hidden">
    <ul class="wrap flex flex-col py-4">
      {
        [...navItems, contactItem].map((item) => (
          <li>
            <a href={item.href} class="block py-3 text-sm font-medium">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const panel = document.getElementById('mobile-nav');
  if (btn && panel) {
    btn.addEventListener('click', () => {
      const nowHidden = panel.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', String(!nowHidden));
    });
  }
</script>
