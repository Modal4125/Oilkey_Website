---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Hero from './Hero.astro';
import SpecPanel from './SpecPanel.astro';
import Button from './Button.astro';
import SectionHeading from './SectionHeading.astro';
import Eyebrow from './Eyebrow.astro';
import ProductCard from './ProductCard.astro';
import CatalogueRow from './CatalogueRow.astro';
import NewsRow from './NewsRow.astro';
import { home, type Lang } from '../i18n/home';
import { news as newsCopy } from '../i18n/news';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = home[lang];
const contactUrl = getRelativeLocaleUrl(lang, '/contact');
const newsListUrl = getRelativeLocaleUrl(lang, '/news');
const catalogueUrl = getRelativeLocaleUrl(lang, '/catalogue');

const latestPosts = (await getCollection('news', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postUrl = (id: string) => getRelativeLocaleUrl(lang, `/news/${id.replace(/^(ja|en)\//, '')}`);
---

<Hero eyebrow={t.hero.eyebrow} lead={t.hero.lead}>
  <Fragment slot="heading">
    {t.hero.headingPre}<br /><em class="text-amber not-italic">{t.hero.headingEm}</em>{
      t.hero.headingPost
    }
  </Fragment>
  <Fragment slot="buttons">
    <Button href="#catalogue" variant="primary">{t.hero.catalogueCta}</Button>
    <Button href="#contact" variant="outline">{t.hero.contactCta}</Button>
  </Fragment>
  <SpecPanel slot="panel" tone="light" title={t.hero.spec.title} rows={t.hero.spec.rows} />
</Hero>

<div class="bg-deep text-white">
  <div class="wrap">
    <div class="grid grid-cols-2 gap-px bg-white/15 lg:grid-cols-4">
      {
        t.trust.map((item) => (
          <div class="bg-deep px-5 py-[30px] text-center">
            <div class="font-display text-[30px] font-bold">{item.num}</div>
            <div class="mt-1.5 text-xs text-white/70">{item.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<section id="business" class="py-16 lg:py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.business.eyebrow} intro={t.business.intro}>
      {t.business.headingLines[0]}<br />{t.business.headingLines[1]}
    </SectionHeading>
    <div class="grid gap-6 lg:grid-cols-3">
      {
        t.business.pillars.map((pillar) => (
          <div class="border-line bg-panel border-t-amber hover:border-amber rounded-xs border border-t-[3px] px-[30px] py-9 transition-[transform,border-color] duration-200 hover:-translate-y-1">
            <div class="text-amber mb-4 font-mono text-xs font-semibold">{pillar.tag}</div>
            <h3 class="mb-3 text-[19px] font-bold">{pillar.title}</h3>
            <p class="text-steel text-sm">{pillar.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section id="products" class="py-16 lg:py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.products.eyebrow} intro={t.products.intro}>
      {t.products.heading}
    </SectionHeading>
    <div class="grid grid-cols-2 gap-5 lg:grid-cols-4">
      {
        t.products.items.map((item) => (
          <ProductCard
            icon={item.icon}
            title={item.title}
            body={item.body}
            href="#catalogue"
            linkLabel={t.products.linkLabel}
          />
        ))
      }
    </div>
  </div>
</section>

<section class="border-line bg-panel border-y py-16 lg:py-[88px]">
  <div class="wrap">
    <div class="mb-9">
      <Eyebrow>{t.apps.eyebrow}</Eyebrow>
      <h2 class="mt-3.5 text-[22px]">{t.apps.heading}</h2>
    </div>
    <div class="flex flex-wrap gap-3">
      {
        t.apps.items.map((label) => (
          <div class="border-line bg-paper hover:border-amber hover:text-amber rounded-xs border px-[22px] py-3.5 text-[15px] font-bold transition-colors">
            {label}
          </div>
        ))
      }
    </div>
  </div>
</section>

<section id="catalogue" class="py-16 lg:py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.catalogue.eyebrow} intro={t.catalogue.intro}>
      {t.catalogue.heading}
    </SectionHeading>
    <div class="border-line bg-panel overflow-hidden rounded-xs border">
      {
        t.catalogue.rows.map((row) => (
          <CatalogueRow
            badge={row.badge}
            title={row.title}
            meta={row.meta}
            href={catalogueUrl}
            label={t.catalogue.download}
          />
        ))
      }
    </div>
  </div>
</section>

<section id="news" class="border-line bg-panel border-t py-16 lg:py-[100px]">
  <div class="mx-auto max-w-[820px] px-8">
    <SectionHeading eyebrow={t.news.eyebrow}>{t.news.heading}</SectionHeading>
    <div class="flex flex-col">
      {
        latestPosts.map((post) => (
          <NewsRow
            date={post.data.date}
            tag={post.data.tag}
            title={post.data.title}
            href={postUrl(post.id)}
          />
        ))
      }
    </div>
    <a href={newsListUrl} class="text-blueprint mt-8 inline-block font-mono text-xs font-medium">
      {newsCopy[lang].viewAll}
    </a>
  </div>
</section>

<section id="contact" class="bg-deep py-16 text-center text-white lg:py-[100px]">
  <div class="wrap">
    <h2 class="mb-4 text-[clamp(24px,3vw,32px)] text-white">{t.cta.heading}</h2>
    <p class="mx-auto mb-8 max-w-[520px] text-[15px] text-white/75">{t.cta.body}</p>
    <div class="flex flex-wrap justify-center gap-3.5">
      <Button href={contactUrl} variant="primary">{t.cta.form}</Button>
      <Button href={t.cta.telHref} variant="outline" tone="dark">{t.cta.tel}</Button>
    </div>
  </div>
</section>
