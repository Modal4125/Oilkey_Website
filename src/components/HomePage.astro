---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Hero from './Hero.astro';
import SpecPanel from './SpecPanel.astro';
import Button from './Button.astro';
import SectionHeading from './SectionHeading.astro';
import Eyebrow from './Eyebrow.astro';
import ProductCard from './ProductCard.astro';
import CatalogueRow from './CatalogueRow.astro';
import NewsRow from './NewsRow.astro';
import { home, type Lang } from '../i18n/home';
import { news as newsCopy } from '../i18n/news';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = home[lang];
const contactUrl = getRelativeLocaleUrl(lang, '/contact');
const newsListUrl = getRelativeLocaleUrl(lang, '/news');

const latestPosts = (await getCollection('news', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postUrl = (id: string) => getRelativeLocaleUrl(lang, `/news/${id.replace(/^(ja|en)\//, '')}`);
---

<Hero eyebrow={t.hero.eyebrow} lead={t.hero.lead}>
  <Fragment slot="heading">
    {t.hero.headingPre}<br /><em class="text-amber not-italic">{t.hero.headingEm}</em>{
      t.hero.headingPost
    }
  </Fragment>
  <Fragment slot="buttons">
    <Button href="#catalogue" variant="primary">{t.hero.catalogueCta}</Button>
    <Button href="#contact" variant="outline">{t.hero.contactCta}</Button>
  </Fragment>
  <SpecPanel slot="panel" title={t.hero.spec.title} rows={t.hero.spec.rows} />
</Hero>

<div class="border-line bg-panel border-b">
  <div class="wrap grid grid-cols-2 lg:grid-cols-4">
    {
      t.trust.map((item) => (
        <div class="border-line border-l px-5 py-[26px] text-center first:border-l-0">
          <div class="text-blueprint font-mono text-[26px] font-semibold">{item.num}</div>
          <div class="text-steel mt-1 text-xs">{item.label}</div>
        </div>
      ))
    }
  </div>
</div>

<section id="business" class="py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.business.eyebrow} intro={t.business.intro}>
      {t.business.headingLines[0]}<br />{t.business.headingLines[1]}
    </SectionHeading>
    <div class="border-line bg-line grid gap-px border lg:grid-cols-3">
      {
        t.business.pillars.map((pillar) => (
          <div class="bg-panel px-[30px] py-9">
            <div class="text-amber mb-4 font-mono text-xs">{pillar.tag}</div>
            <h3 class="mb-3 text-[19px] font-bold">{pillar.title}</h3>
            <p class="text-steel text-sm">{pillar.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section id="products" class="border-line bg-panel border-y py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.products.eyebrow} intro={t.products.intro}>
      {t.products.heading}
    </SectionHeading>
    <div class="grid grid-cols-2 gap-5 lg:grid-cols-4">
      {
        t.products.items.map((item) => (
          <ProductCard
            icon={item.icon}
            title={item.title}
            body={item.body}
            href="#catalogue"
            linkLabel={t.products.linkLabel}
          />
        ))
      }
    </div>
  </div>
</section>

<div class="bg-ink text-paper">
  <div class="wrap">
    <div class="pt-14">
      <Eyebrow tone="amber">{t.apps.eyebrow}</Eyebrow>
      <h2 class="mt-3.5 text-[22px] text-white">{t.apps.heading}</h2>
    </div>
    <div class="grid grid-cols-3 border-t border-white/[0.14] lg:grid-cols-6">
      {
        t.apps.items.map((label, i) => (
          <div class="border-l border-white/[0.14] px-3.5 py-[30px] text-center text-[13px] text-[#c7cdd1] first:border-l-0">
            <span class="text-amber mb-2.5 block font-mono text-[11px]">
              {String(i + 1).padStart(2, '0')}
            </span>
            {label}
          </div>
        ))
      }
    </div>
  </div>
</div>

<section id="catalogue" class="bg-panel py-[100px]">
  <div class="wrap">
    <SectionHeading eyebrow={t.catalogue.eyebrow} intro={t.catalogue.intro}>
      {t.catalogue.heading}
    </SectionHeading>
    <div class="border-line border">
      {
        t.catalogue.rows.map((row) => (
          <CatalogueRow
            badge={row.badge}
            title={row.title}
            meta={row.meta}
            href="#"
            label={t.catalogue.download}
          />
        ))
      }
    </div>
  </div>
</section>

<section id="news" class="border-line bg-panel border-t py-[100px]">
  <div class="mx-auto max-w-[820px] px-8">
    <SectionHeading eyebrow={t.news.eyebrow}>{t.news.heading}</SectionHeading>
    <div class="flex flex-col">
      {
        latestPosts.map((post) => (
          <NewsRow
            date={post.data.date}
            tag={post.data.tag}
            title={post.data.title}
            href={postUrl(post.id)}
          />
        ))
      }
    </div>
    <a href={newsListUrl} class="text-blueprint mt-8 inline-block font-mono text-xs font-medium">
      {newsCopy[lang].viewAll}
    </a>
  </div>
</section>

<section id="contact" class="bg-blueprint-dark py-[100px] text-center text-white">
  <div class="wrap">
    <h2 class="mb-4 text-[clamp(24px,3vw,32px)]">{t.cta.heading}</h2>
    <p class="mx-auto mb-8 max-w-[520px] text-[15px] text-[#b9cbd5]">{t.cta.body}</p>
    <div class="flex flex-wrap justify-center gap-3.5">
      <Button href={contactUrl} variant="primary">{t.cta.form}</Button>
      <Button href={t.cta.telHref} variant="outline">{t.cta.tel}</Button>
    </div>
  </div>
</section>
