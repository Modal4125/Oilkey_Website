---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow: string;
  heading: string;
  intro?: string;
}

const { eyebrow, heading, intro } = Astro.props;
---

<div class="border-line bg-panel border-b">
  <div class="wrap py-[72px]">
    <Eyebrow class="mb-4">{eyebrow}</Eyebrow>
    <h1 class="text-[clamp(30px,3.6vw,44px)] leading-[1.3]">{heading}</h1>
    {intro && <p class="text-steel mt-4 max-w-[640px] text-[15px]">{intro}</p>}
  </div>
</div>
