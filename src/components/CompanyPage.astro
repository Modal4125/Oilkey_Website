---
import PageHeader from './PageHeader.astro';
import SectionHeading from './SectionHeading.astro';
import SpecPanel from './SpecPanel.astro';
import SpecRow from './SpecRow.astro';
import { company } from '../i18n/company';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = company[lang];
---

<PageHeader eyebrow={t.header.eyebrow} heading={t.header.heading} />

<section class="py-20">
  <div class="mx-auto max-w-[820px] px-8">
    <SpecPanel tone="light" title={t.overview.title}>
      {t.overview.rows.map((row) => <SpecRow k={row.k} v={row.v} mono={row.mono} />)}
    </SpecPanel>
  </div>
</section>

<section class="pb-20">
  <div class="mx-auto max-w-[820px] px-8">
    <SectionHeading eyebrow={t.message.eyebrow}>{t.message.heading}</SectionHeading>
    <div class="space-y-5 text-[15px]">
      {t.message.paras.map((para) => <p>{para}</p>)}
    </div>
  </div>
</section>

<section class="pb-20">
  <div class="mx-auto max-w-[820px] px-8">
    <SectionHeading eyebrow={t.access.eyebrow}>{t.access.heading}</SectionHeading>
    <ul>
      {
        t.access.items.map((item) => (
          <li class="border-line text-steel border-t py-3 text-sm first:border-t-0">{item}</li>
        ))
      }
    </ul>
    {t.access.note && <p class="text-steel-light mt-5 text-[13px] italic">{t.access.note}</p>}
  </div>
</section>
