---
import Crosshair from './Crosshair.astro';

interface Props {
  tone?: 'blueprint' | 'amber';
  class?: string;
}

const { tone = 'blueprint', class: className } = Astro.props;
---

<div
  class:list={[
    'flex items-center gap-2 font-mono text-xs tracking-[0.14em] uppercase',
    tone === 'amber' ? 'text-amber' : 'text-blueprint',
    className,
  ]}
>
  <Crosshair size="sm" class="text-amber" />
  <slot />
</div>
