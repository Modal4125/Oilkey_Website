---
interface Props {
  tone?: 'blueprint' | 'amber';
  class?: string;
}

const { tone = 'amber', class: className } = Astro.props;
---

<div
  class:list={[
    'text-xs font-bold tracking-[0.16em] uppercase',
    tone === 'blueprint' ? 'text-blueprint' : 'text-amber',
    className,
  ]}
>
  <slot />
</div>
