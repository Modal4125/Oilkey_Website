---
interface Props {
  href?: string;
  /** Rendered as <button type={type}> when no href is given */
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'outline';
  /** Background context for the outline variant */
  tone?: 'dark' | 'light';
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  tone = 'light',
  class: className,
} = Astro.props;

const Tag = href ? 'a' : 'button';

const variantClasses =
  variant === 'primary'
    ? 'bg-amber text-white hover:bg-amber-bright'
    : tone === 'dark'
      ? 'border-2 border-white/40 text-white hover:border-white'
      : 'border-2 border-line-dark text-ink hover:border-amber hover:text-amber';
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={[
    'inline-flex items-center gap-2.5 rounded-xs px-7 py-3.5 text-[15px] font-bold transition-[transform,background-color,border-color,color] duration-150 hover:-translate-y-0.5',
    !href && 'cursor-pointer',
    variantClasses,
    className,
  ]}
>
  <slot />
</Tag>
