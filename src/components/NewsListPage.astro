---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import PageHeader from './PageHeader.astro';
import NewsRow from './NewsRow.astro';
import { news } from '../i18n/news';
import type { Lang } from '../i18n/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = news[lang];

const posts = (await getCollection('news', ({ data }) => data.lang === lang && !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const postUrl = (id: string) => getRelativeLocaleUrl(lang, `/news/${id.replace(/^(ja|en)\//, '')}`);
---

<PageHeader eyebrow={t.header.eyebrow} heading={t.header.heading} intro={t.header.intro} />

<section class="py-20">
  <div class="mx-auto max-w-[820px] px-8">
    <div class="flex flex-col">
      {
        posts.map((post) => (
          <NewsRow
            date={post.data.date}
            tag={post.data.tag}
            title={post.data.title}
            href={postUrl(post.id)}
          />
        ))
      }
    </div>
    {posts.length === 0 && <p class="text-steel text-sm">{t.empty}</p>}
  </div>
</section>
