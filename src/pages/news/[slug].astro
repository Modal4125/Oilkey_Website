---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NewsPostPage from '../../components/NewsPostPage.astro';
import { news } from '../../i18n/news';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => data.lang === 'ja' && !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^ja\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const t = news.ja;
---

<Layout
  title={`${post.data.title} | オイルキー株式会社`}
  description={t.meta.description}
  lang="ja"
  ogType="article"
>
  <NewsPostPage lang="ja" post={post} />
</Layout>
